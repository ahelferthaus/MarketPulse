# Westwood MarketPulse — Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# OPERATING MODE
# =============================================================================
MARKETPULSE_MODE=public                  # public | premium | professional
ENABLED_PROVIDERS=yfinance,fred,cboe,rss,mock
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR

# =============================================================================
# PATHS
# =============================================================================
DATA_DIR=./data
DUCKDB_PATH=./data/marketpulse.duckdb
CACHE_PATH=./data/cache.sqlite
EXPORTS_DIR=./data/exports
STATIC_PAYLOADS_DIR=./data/static_site_payloads

# =============================================================================
# API KEYS — PUBLIC MODE (Free, no keys needed for most)
# =============================================================================
# FRED API key is optional — many series work without it
# Get one free at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# =============================================================================
# API KEYS — PREMIUM MODE (Paid subscriptions)
# =============================================================================
# Financial Modeling Prep — https://financialmodelingprep.com/
FMP_API_KEY=

# NewsAPI — https://newsapi.org/
NEWSAPI_KEY=

# =============================================================================
# API KEYS — PROFESSIONAL MODE (Bloomberg, Morningstar, etc.)
# =============================================================================
# Bloomberg MCP — path to MCP server executable
BLOOMBERG_MCP_PATH=

# Morningstar MCP — path to MCP server executable
MORNINGSTAR_MCP_PATH=

# =============================================================================
# SOCIAL MEDIA API KEYS (Stubs — implement when APIs available)
# =============================================================================
X_API_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=MarketPulse/1.0
STOCKTWITS_API_KEY=

# =============================================================================
# UPDATE SCHEDULE
# =============================================================================
DAILY_UPDATE_TIME=16:30                  # ET time for daily full calculation
INTRADAY_REFRESH_MINUTES=15              # Minutes between intraday refreshes
CACHE_TTL_MINUTES=5                      # API response cache TTL

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_NARRATIVE=true
ENABLE_POSITIONING=true
ENABLE_NLP_LLM=false                     # LLM summarization (on-demand only)
ENABLE_BACKTEST=true
ENABLE_ADMIN_ENDPOINTS=true

# =============================================================================
# SCORING CONFIGURATION
# =============================================================================
NORMALIZATION_METHOD=rolling_percentile  # rolling_percentile | min_max | z_score
ROLLING_WINDOW_DAYS=252                  # 1 year lookback for normalization
CLASSIC_WEIGHT=0.40                      # Composite weight for Classic
NARRATIVE_WEIGHT=0.30                    # Composite weight for Narrative
POSITIONING_WEIGHT=0.30                  # Composite weight for Positioning

# =============================================================================
# FRONTEND
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=MarketPulse
NEXT_PUBLIC_COMPANY_NAME=Westwood
