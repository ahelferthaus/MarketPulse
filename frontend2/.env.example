# Frontend data source configuration.
#
# Leave VITE_API_BASE_URL UNSET (the default) to run in STATIC mode: the app
# reads pre-generated JSON from <base>/data/*.json. Regenerate those files with:
#
#   python -m backend.jobs.generate_frontend_payloads
#
# Set VITE_API_BASE_URL to run in LIVE mode against the FastAPI backend. Vite
# inlines this at build time, so rebuild after changing it.
#
#   Local backend:   VITE_API_BASE_URL=http://localhost:8000
#   Hosted backend:  VITE_API_BASE_URL=https://your-backend.example.com
#
# VITE_API_BASE_URL=http://localhost:8000
